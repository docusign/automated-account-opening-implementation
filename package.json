{
  "name": "extension-app-data-io-and-verification-reference-implementation",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc --build tsconfig.json && npm run copy-views && npm run copy-files",
    "lint": "npx eslint --ext .ts src/",
    "start": "node ./dist --env=development",
    "dev": "nodemon",
    "copy-views": "run-script-os",
    "copy-views:windows": "xcopy views dist\\views /E /I /Y",
    "copy-views:default": "cp -r views dist/",
    "copy-files": "run-script-os",
    "copy-files:windows": "xcopy src\\dataModel dist\\dataModel /E /I /Y && xcopy src\\db\\*.json dist\\db /E /I /Y",
    "copy-files:default": "cp -r src/dataModel dist/dataModel && cp src/db/*.json dist/db/"
  },
  "nodemonConfig": {
    "watch": [
      "src",
      "views"
    ],
    "ext": "ts, pug",
    "exec": "./node_modules/.bin/ts-node --files -r tsconfig-paths/register ./src"
  },
  "dependencies": {
    "@accordproject/concerto-cli": "^3.18.1",
    "@accordproject/concerto-core": "~3.25.7",
    "@accordproject/concerto-types": "~3.25.7",
    "ajv": "^8.18.0",
    "axios": "^1.6.7",
    "body-parser": "^1.20.2",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-jwt": "^8.5.1",
    "express-validator": "^7.3.1",
    "fs": "0.0.2",
    "helmet": "^8.1.0",
    "i18next": "^25.8.13",
    "install": "^0.13.0",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "morgan": "^1.10.1",
    "node-forge": "^1.3.0",
    "npm": "^11.10.0",
    "prompt-sync": "^4.2.0",
    "pug": "^3.0.3",
    "querystring": "^0.2.0",
    "run-script-os": "1.1.6",
    "ts-command-line-args": "^2.5.1",
    "ts-force": "^3.5.0",
    "upper-case": "^1.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.2.3",
    "@types/pug": "^2.0.10",
    "@typescript-eslint/eslint-plugin": "^5.59.7",
    "@typescript-eslint/parser": "^5.59.7",
    "cpx": "^1.5.0",
    "eslint": "^8.57.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.4",
    "typescript-eslint": "^8.20.0"
  },
  "overrides": {
    "braces": "^3.0.3",
    "micromatch": "^4.0.8",
    "undici": "^6.23.0"
  }
}
